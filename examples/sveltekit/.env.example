# Agent planner mode: mock works without credentials; openai calls gruntend/generate + pi-ai/OpenAI.
GRUNTEND_AGENT_MODE=mock

# Enable a small browser-side debug drawer on /agent.
PUBLIC_GRUNTEND_AGENT_DEBUG=false

# Required only when GRUNTEND_AGENT_MODE=openai.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.1
