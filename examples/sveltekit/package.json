{
  "name": "gruntend-sveltekit-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "pnpm build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply gruntend-example --local",
    "d1:migrate:remote": "wrangler d1 migrations apply gruntend-example --remote"
  },
  "dependencies": {
    "@sveltejs/adapter-cloudflare": "7.2.9",
    "@sveltejs/kit": "2.69.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "gruntend": "workspace:*",
    "svelte": "5.56.4",
    "valibot": "1.4.0",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "svelte-check": "4.7.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.8.3",
    "wrangler": "4.110.0"
  }
}
