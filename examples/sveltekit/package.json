{
  "name": "gruntend-sveltekit-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --dir ../.. build",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "pnpm --dir ../.. build",
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "pnpm build && wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply gruntend-demo --local",
    "d1:migrate:remote": "wrangler d1 migrations apply gruntend-demo --remote"
  },
  "dependencies": {
    "@sveltejs/adapter-cloudflare": "7.2.9",
    "@sveltejs/kit": "2.57.0",
    "@sveltejs/vite-plugin-svelte": "6.0.0",
    "gruntend-sdk": "workspace:*",
    "lucide-svelte": "1.0.1",
    "svelte": "5.49.1",
    "valibot": "1.4.0",
    "vite": "7.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "svelte-check": "4.7.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.8.3",
    "wrangler": "4.110.0"
  }
}
