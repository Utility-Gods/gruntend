---
import { Code } from "astro:components";

const plan = `// JavaScript plan generated by the LLM from the user's intent.
const menus = await tools.menus.list({});
const itemGroups = await Promise.all(
  menus.menus.map((menu) =>
    tools.menu.items.list({ menuId: menu.menuId })
  )
);

const changes = itemGroups
  .flatMap((group, index) =>
    group.items.map((item) => ({
      ...item,
      menuName: menus.menus[index].name,
    }))
  )
  .filter(({ price }) => price < 10)
  .map((item) => ({
    ...item,
    nextPrice: item.price * 1.2,
  }));

let message = "";
const applyChanges = async () => {
  await Promise.all(changes.map((change) =>
    tools.menu.item.update({
      menuId: change.menuId,
      itemId: change.itemId,
      price: change.nextPrice,
    })
  ));
  message = \`\${changes.length} prices updated.\`;
};

const render = () => html\`<section class="price-review">
  <header>
    <div><small>Generated for this task</small><h2>Price review</h2></div>
    <b>\${changes.length} items</b>
  </header>
  <div class="price-list">\${changes.map((change) => html\`
    <article>
      <span><strong>\${change.name}</strong><small>\${change.menuName}</small></span>
      <span><del>$\${change.price.toFixed(2)}</del><b>$\${change.nextPrice.toFixed(2)}</b></span>
    </article>
  \`)}</div>
  <footer>
    <button onclick=\${applyChanges}>Apply all changes</button>
    <span>\${message || "No mutation until confirmation"}</span>
  </footer>
</section>\`;

return render;`;
---

<runtime-walkthrough class="not-content">
  <div class="browser-bar">
    <strong>Runtime trace</strong>
    <div class="timeline" aria-hidden="true"><i class="active"></i><i></i><i></i><i></i><i></i></div>
    <span class="execution-status"><i aria-hidden="true"></i><b>Live execution</b></span>
    <span class="step-count" aria-live="polite">1 of 5</span>
  </div>

  <div class="stages">
    <section role="tabpanel" id="stage-intent" aria-labelledby="tab-intent">
      <div class="intent-surface">
        <header><code>your.webapp.com</code></header>
        <div class="intent-entry">
          <p aria-label="Show every menu item under $10 and preview a 20% price increase.">
            <span class="typed-query"></span><i class="typing-caret" aria-hidden="true"></i>
          </p>
          <button type="button">Run</button>
        </div>
      </div>
    </section>

    <section role="tabpanel" id="stage-plan" aria-labelledby="tab-plan" hidden>
      <Code code={plan} lang="javascript" theme="github-dark" wrap />
    </section>

    <section role="tabpanel" id="stage-interpreter" aria-labelledby="tab-interpreter" hidden>
      <div class="console">
        <header><span>gruntend-runtime</span><b>Interpreter session</b></header>
        <div class="console-lines">
          <p><i>$</i><span>parse plan.js</span><b>ready</b></p>
          <p><i>+</i><span>globals: input, tools, Promise, html</span><b>provided</b></p>
          <p><i>−</i><span>fetch, window, document, eval</span><b class="blocked">blocked</b></p>
          <p><i>›</i><span>execute interpreted JavaScript</span><b class="running">running</b></p>
        </div>
      </div>
    </section>

    <section role="tabpanel" id="stage-handlers" aria-labelledby="tab-handlers" hidden>
      <div class="boundary-trace">
        <header><strong>Generated plan</strong><span>registered capability boundary</span><strong>Application</strong></header>
        <div class="boundary-call">
          <code>tools.menus.list({})</code><span>→</span><b>menus.list handler</b><em>4 menus</em>
        </div>
        <div class="boundary-call">
          <code>tools.menu.items.list(…)</code><span>→</span><b>menu items handler</b><em>19 items</em>
        </div>
        <footer>Permissions, validation, and persistence remain inside application code.</footer>
      </div>
    </section>

    <section role="tabpanel" id="stage-result" aria-labelledby="tab-result" hidden>
      <div class="result-preview">
        <header><span><small>Generated for this task</small><strong>Price review</strong></span><b>3 items</b></header>
        <p><span>Truffle Fries <small>Dinner menu</small></span><span><del>$8.00</del><strong>$9.60</strong></span></p>
        <p><span>Cold Brew <small>Drinks menu</small></span><span><del>$5.00</del><strong>$6.00</strong></span></p>
        <p><span>Ginger Lemonade <small>Drinks menu</small></span><span><del>$6.00</del><strong>$7.20</strong></span></p>
        <footer><button type="button">Apply all changes</button><span>No mutation until confirmation</span></footer>
      </div>
    </section>
  </div>

  <div class="tabs" role="tablist" aria-label="Runtime stages">
    <button role="tab" aria-selected="true" aria-controls="stage-intent" id="tab-intent">Intent</button>
    <button role="tab" aria-selected="false" aria-controls="stage-plan" id="tab-plan" tabindex="-1">JavaScript plan</button>
    <button role="tab" aria-selected="false" aria-controls="stage-interpreter" id="tab-interpreter" tabindex="-1">Interpreter</button>
    <button role="tab" aria-selected="false" aria-controls="stage-handlers" id="tab-handlers" tabindex="-1">Tools & handlers</button>
    <button role="tab" aria-selected="false" aria-controls="stage-result" id="tab-result" tabindex="-1">Generated UI</button>
  </div>
</runtime-walkthrough>

<script>
  class RuntimeWalkthrough extends HTMLElement {
    private buttons: HTMLButtonElement[] = [];
    private panels: HTMLElement[] = [];
    private current = 0;
    private timer?: number;
    private typingTimer?: number;

    connectedCallback() {
      this.buttons = Array.from(this.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
      this.panels = Array.from(this.querySelectorAll<HTMLElement>('[role="tabpanel"]'));

      this.buttons.forEach((button, index) => {
        button.addEventListener('click', () => {
          this.dataset.manual = 'true';
          this.stop();
          this.show(index);
          const status = this.querySelector<HTMLElement>('.execution-status b');
          if (status) status.textContent = 'Manual control';
        });
      });

      this.addEventListener('pointerenter', () => this.stop());
      this.addEventListener('pointerleave', () => this.start());
      this.addEventListener('focusin', () => this.stop());
      this.addEventListener('focusout', () => this.start());
      this.typeIntent();
      this.start();
    }

    disconnectedCallback() {
      this.stop();
      if (this.typingTimer) window.clearInterval(this.typingTimer);
    }

    private show(index: number) {
      this.current = index;
      this.buttons.forEach((button, buttonIndex) => {
        const active = buttonIndex === index;
        button.setAttribute('aria-selected', String(active));
        button.tabIndex = active ? 0 : -1;
      });
      this.panels.forEach((panel, panelIndex) => {
        panel.hidden = panelIndex !== index;
      });
      if (index === 0) this.typeIntent();
      this.dataset.step = String(index);
      this.querySelectorAll<HTMLElement>('.timeline i').forEach((dot, dotIndex) => {
        dot.classList.toggle('active', dotIndex <= index);
      });
      const count = this.querySelector<HTMLElement>('.step-count');
      if (count) count.textContent = `${index + 1} of ${this.buttons.length}`;
    }

    private start() {
      if (this.dataset.manual || window.matchMedia('(prefers-reduced-motion: reduce)').matches || this.timer) return;
      this.timer = window.setInterval(() => this.show((this.current + 1) % this.buttons.length), 3500);
    }

    private stop() {
      if (!this.timer) return;
      window.clearInterval(this.timer);
      this.timer = undefined;
    }

    private typeIntent() {
      const target = this.querySelector<HTMLElement>('.typed-query');
      if (!target) return;
      const query = 'Show every menu item under $10 and preview a 20% price increase.';
      if (this.typingTimer) window.clearInterval(this.typingTimer);
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        target.textContent = query;
        return;
      }
      target.textContent = '';
      let index = 0;
      this.typingTimer = window.setInterval(() => {
        target.textContent = query.slice(0, ++index);
        if (index >= query.length && this.typingTimer) {
          window.clearInterval(this.typingTimer);
          this.typingTimer = undefined;
        }
      }, 32);
    }
  }

  customElements.define('runtime-walkthrough', RuntimeWalkthrough);
</script>

<style>
  runtime-walkthrough { display: block; overflow: hidden; border: 1px solid #cbd5e1; background: white; box-shadow: 0 10px 30px rgb(15 23 42 / 8%); }
  .browser-bar { display: grid; grid-template-columns: auto 1fr auto auto; gap: 1rem; align-items: center; min-height: 2.5rem; border-bottom: 1px solid #334155; background: #0f172a; padding: 0 .85rem; color: #cbd5e1; font-size: .62rem; }
  .browser-bar > strong { color: white; font-weight: 650; }
  .execution-status { display: flex; align-items: center; gap: .4rem; }
  .execution-status i { width: .4rem; height: .4rem; border-radius: 50%; background: #22c55e; box-shadow: 0 0 0 3px rgb(34 197 94 / 15%); }
  .execution-status b { font-weight: 600; }
  runtime-walkthrough[data-manual] .execution-status i { background: #fb923c; box-shadow: 0 0 0 3px rgb(251 146 60 / 15%); }
  .step-count { justify-self: end; color: #94a3b8; }
  .timeline { display: flex; justify-content: center; gap: .55rem; }
  .timeline i { width: .45rem; height: .45rem; border: 1px solid #64748b; border-radius: 50%; background: transparent; transition: border-color 180ms ease, background 180ms ease; }
  .timeline i.active { border-color: #f54a00; background: #f54a00; box-shadow: 0 0 0 2px rgb(245 74 0 / 18%); }
  .tabs { display: grid; grid-template-columns: repeat(5, minmax(7rem, 1fr)); gap: .3rem; overflow-x: auto; border-top: 1px solid #cbd5e1; background: white; padding: .6rem; }
  .tabs button { box-sizing: border-box; width: 100%; height: 2rem; min-height: 2rem; margin: 0; align-self: stretch; border: 1px solid #cbd5e1; border-radius: 0; background: white; color: #475569; padding: .35rem .55rem; font: inherit; font-size: .61rem; font-weight: 650; line-height: 1; white-space: nowrap; cursor: pointer; appearance: none; transition: border-color 120ms ease, background 120ms ease, color 120ms ease; }
  .tabs button:hover { border-color: #f54a00; color: #c2410c; }
  .tabs button[aria-selected="true"] { border-color: #f54a00; background: #f54a00; color: white; }
  .tabs button:focus-visible { outline: 2px solid #f54a00; outline-offset: 2px; }
  .stages { height: 22rem; overflow: hidden; background: #0f172a; }
  [role="tabpanel"] { box-sizing: border-box; height: 22rem; overflow: hidden; padding: clamp(1.1rem, 3vw, 2rem); }
  [role="tabpanel"][hidden] { display: none; }
  .stage-label { margin: 0 0 1rem; color: #fb923c; font-size: .62rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  #stage-intent { display: grid; align-items: start; background: #faf9f6; padding-top: 1.25rem; }
  #stage-intent[hidden] { display: none; }
  .intent-surface { width: min(100%, 52rem); margin-inline: auto; border: 1px solid #d6d3d1; background: white; box-shadow: 0 5px 16px rgb(15 23 42 / 7%); }
  .intent-surface header { border-bottom: 1px solid #e7e5e4; background: #f8fafc; padding: .5rem .75rem; }
  .intent-surface header code { color: #64748b; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: .58rem; }
  .intent-entry { display: grid; grid-template-columns: 1fr auto; gap: .55rem; padding: .9rem; }
  .intent-entry p { display: flex; align-items: center; min-height: 2.65rem; margin: 0; border: 1px solid #cbd5e1; padding: .55rem .7rem; color: #334155; font-size: .72rem; line-height: 1.45; }
  .typing-caret { width: 1px; height: 1em; margin-left: 2px; background: #f54a00; animation: caret-blink .8s steps(1) infinite; }
  .intent-entry button { min-width: 4.2rem; border: 1px solid #f54a00; border-radius: 0; background: #f54a00; color: white; padding: .55rem .75rem; font: inherit; font-size: .7rem; font-weight: 700; }
  @keyframes caret-blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .typing-caret { animation: none; } }
  .stage-note { max-width: 43rem; margin: 1rem auto 0; color: #94a3b8; font-size: .72rem; text-align: center; }
  #stage-plan { padding: 0; }
  #stage-plan :global(pre.astro-code) { box-sizing: border-box; height: 22rem; overflow: auto; margin: 0; padding: 1.2rem 1.4rem; border: 0; border-radius: 0; font-size: .72rem; line-height: 1.5; }
  .console { max-width: 48rem; margin: 0 auto; border: 1px solid #334155; background: #0b1220; }
  .console header { display: flex; justify-content: space-between; border-bottom: 1px solid #334155; background: #111c31; padding: .65rem .8rem; color: #94a3b8; font-size: .6rem; }
  .console header span { color: #e2e8f0; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
  .console-lines { padding: .55rem 0; }
  .console-lines p { display: grid; grid-template-columns: 1.25rem 1fr auto; gap: .6rem; align-items: center; margin: 0; padding: .52rem .8rem; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: .66rem; }
  .console-lines i { color: #fb923c; font-style: normal; }
  .console-lines span { color: #cbd5e1; }
  .console-lines b { color: #86efac; font-size: .58rem; font-weight: 600; }
  .console-lines b.blocked { color: #f87171; }
  .console-lines b.running::before { display: inline-block; width: .38rem; height: .38rem; margin-right: .35rem; border-radius: 50%; background: #22c55e; content: ""; }
  #stage-handlers { display: grid; align-items: center; background: #f8fafc; }
  #stage-handlers[hidden] { display: none; }
  .boundary-trace { width: min(100%, 54rem); margin-inline: auto; border: 1px solid #cbd5e1; background: white; color: #0f172a; }
  .boundary-trace header { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; border-bottom: 1px solid #e2e8f0; padding: .7rem .8rem; font-size: .65rem; }
  .boundary-trace header strong:last-child { text-align: right; }
  .boundary-trace header span { color: #f54a00; font-size: .55rem; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; }
  .boundary-call { display: grid; grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) auto; gap: .7rem; align-items: center; border-bottom: 1px solid #e2e8f0; padding: .75rem .8rem; font-size: .65rem; }
  .boundary-call code { overflow: hidden; color: #334155; font-size: .62rem; text-overflow: ellipsis; white-space: nowrap; }
  .boundary-call > span { color: #f54a00; font-size: .9rem; }
  .boundary-call b { color: #0f172a; font-size: .64rem; }
  .boundary-call em { color: #047857; font-size: .58rem; font-style: normal; font-weight: 650; }
  .boundary-trace footer { padding: .65rem .8rem; color: #64748b; font-size: .58rem; }
  .result-preview { max-width: 40rem; margin: 0 auto; border: 1px solid #334155; background: white; color: #0f172a; }
  .result-preview header, .result-preview footer, .result-preview > p { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin: 0; padding: .7rem .85rem; border-bottom: 1px solid #e2e8f0; font-size: .7rem; }
  .result-preview header span > *, .result-preview > p span > * { display: block; }
  .result-preview header small { color: #f54a00; font-size: .55rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; }
  .result-preview header > b { background: #ecfdf5; color: #047857; padding: .2rem .4rem; font-size: .58rem; }
  .result-preview p small { color: #94a3b8; }
  .result-preview p span:last-child { display: flex; gap: .7rem; }
  .result-preview p span:last-child strong { color: #c2410c; }
  .result-preview footer { border-bottom: 0; }
  .result-preview footer button { border: 0; border-radius: 0; background: #f54a00; color: white; padding: .55rem .75rem; font: inherit; font-size: .65rem; font-weight: 650; }
  .result-preview footer span { color: #64748b; font-size: .6rem; }
  @media (max-width: 40rem) { .browser-bar { grid-template-columns: auto 1fr auto; } .execution-status { display: none; } .boundary-call { grid-template-columns: 1fr auto; } .boundary-call b { grid-column: 1; } .stages, [role="tabpanel"] { height: 24rem; } #stage-plan :global(pre.astro-code) { height: 24rem; } }
</style>
