---
const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline } = data.hero || {};
const isHomepage = Astro.url.pathname === "/";
---

<section class="product-hero">
  <div class="hero-copy">
    <p class="eyebrow">Semantic application runtime · v0.1.0 beta</p>
    <h1 id="_top" data-page-title set:html={title} />
    {tagline && <p class="tagline" set:html={tagline} />}
    <div class="hero-actions">
      <a class="primary-action" href="/overview/">Understand how it works <span>→</span></a>
      <a class="secondary-action" href="https://demo.gruntend.com/" target="_blank" rel="noreferrer">Open the demo <span>↗</span></a>
    </div>
    {isHomepage && <p class="runtime-note">Plans run through the built-in <a href="https://github.com/badlogic/jailjs" target="_blank" rel="noreferrer">JailJS</a> interpreter, not <code>eval</code> or <code>Function</code>.</p>}
  </div>
</section>

<style>
  .product-hero { display: flex; justify-content: center; padding: clamp(1.75rem, 3.5vw, 3rem) 0 clamp(1.5rem, 2.5vw, 2rem); text-align: center; }
  .hero-copy { width: 100%; max-width: 62rem; }
  .eyebrow { margin: 0 0 .65rem; color: #f54a00; font-size: .75rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; }
  h1 { margin: 0; color: #0f172a; font-size: clamp(2.5rem, 4.4vw, 3.8rem); font-weight: 680; letter-spacing: -.055em; line-height: 1.02; }
  .tagline { max-width: 52rem; margin: .95rem auto 0; color: #475569; font-size: 1.02rem; line-height: 1.7; }
  .hero-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: .75rem; margin-top: 1.25rem; }
  .hero-actions a { display: inline-flex; align-items: center; justify-content: center; gap: .7rem; min-height: 2.8rem; padding: .7rem 1rem; border: 1px solid #f54a00; border-radius: 0; font-size: .84rem; font-weight: 650; text-decoration: none; }
  .primary-action { background: #f54a00; color: white; }
  .primary-action:hover { background: #c2410c; border-color: #c2410c; }
  .secondary-action { background: white; color: #c2410c; }
  .secondary-action:hover { background: #fff7ed; }
  .runtime-note { margin: .7rem 0 0; color: #64748b; font-size: .67rem; }
  .runtime-note a { color: #334155; font-weight: 700; text-decoration-color: #f54a00; }
  .runtime-note code { border: 1px solid #e2e8f0; background: #f8fafc; padding: .08rem .2rem; color: #334155; }
</style>
