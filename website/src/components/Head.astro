---
const { head, entry } = Astro.locals.starlightRoute;
const isHomepage = Boolean(entry.data.hero);
const socialImage = new URL("/og.png", Astro.site);
const tags = isHomepage
  ? head.map((item) =>
      item.tag === "meta" && item.attrs?.property === "og:type"
        ? { ...item, attrs: { ...item.attrs, content: "website" } }
        : item,
    )
  : head;
---

<link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
{tags.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
{isHomepage && (
  <>
    <meta property="og:image" content={socialImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Gruntend homepage showing the intent-to-interface runtime walkthrough" />
    <meta name="twitter:image" content={socialImage.href} />
    <meta name="twitter:image:alt" content="Gruntend homepage showing the intent-to-interface runtime walkthrough" />
  </>
)}
