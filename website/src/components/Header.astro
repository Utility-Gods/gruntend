---
import Search from "virtual:starlight/components/Search";
const pathname = Astro.url.pathname;
const links = [
  { label: "How it works", href: "/overview/" },
  { label: "Build", href: "/getting-started/" },
  { label: "Reference", href: "/reference/api/" },
];
---

<header class="app-header">
  <a class="brand" href="/">Gruntend <span>Beta</span></a>
  <nav aria-label="Primary navigation">
    {links.map((link) => (
      <a class:list={{ active: pathname.startsWith(link.href.split('/').slice(0, -1).join('/')) && pathname !== '/' }} href={link.href}>
        {link.label}
      </a>
    ))}
    <a href="https://demo.gruntend.com/" target="_blank" rel="noreferrer">Demo ↗</a>
  </nav>
  <div class="header-tools">
    <Search />
    <a class="github-link" href="https://github.com/Utility-Gods/gruntend" target="_blank" rel="noreferrer" aria-label="Gruntend on GitHub">
      <img src="/github.svg" width="16" height="16" alt="" />
    </a>
  </div>
</header>

<style>
  .app-header { display: flex; height: 100%; align-items: stretch; justify-content: space-between; gap: 1.25rem; }
  .brand { display: flex; align-items: center; gap: .45rem; color: #0f172a; font-size: 1rem; font-weight: 750; letter-spacing: -.03em; text-decoration: none; }
  .brand span { border: 1px solid #f54a00; padding: .12rem .28rem; color: #c2410c; font-size: .48rem; font-weight: 750; letter-spacing: .08em; line-height: 1; text-transform: uppercase; }
  nav { display: none; align-items: stretch; gap: .2rem; }
  nav a { display: flex; align-items: center; margin-block: .65rem; padding: .4rem .7rem; color: #64748b; font-size: .72rem; font-weight: 650; text-decoration: none; }
  nav a:hover, nav a.active { background: #f54a00; color: white; }
  .header-tools { display: flex; align-items: center; gap: 1rem; }
  .header-tools :global(site-search) { width: min(16rem, 26vw); }
  .github-link { display: flex; opacity: .78; }
  .github-link:hover { opacity: 1; }
  .github-link img { display: block; }
  @media (min-width: 64rem) { nav { display: flex; } }
</style>
